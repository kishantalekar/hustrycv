# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:android)

platform :android do
  desc "Runs all the tests"
  lane :test do
    gradle(task: "test")
  end

  desc "Submit a new Beta Build to Crashlytics Beta"
  lane :beta do
    gradle(task: "clean assembleRelease")
    crashlytics
  
    # sh "your_script.sh"
    # You can also use other beta testing services here
  end

  private_lane :get_next_version_code do
    tracks = ['internal', 'alpha', 'beta', 'production']
    max_version_code = 0
    tracks.each do |t|
      begin
        codes = google_play_track_version_codes(track: t)
        if codes && !codes.empty?
          track_max = codes.max
          max_version_code = track_max if track_max > max_version_code
        end
      rescue => ex
        UI.message("Could not fetch version codes for track #{t}: #{ex.message}")
      end
    end
    
    if max_version_code > 0
      max_version_code + 1
    else
      nil
    end
  end

  desc "Deploy a new version to the Google Play"
  lane :deploy do |options|
    track = options[:track] || ENV["PLAY_STORE_TRACK"] || "production"

    next_version = get_next_version_code
    if next_version
      increment_version_code(gradle_file_path: "app/build.gradle", version_code: next_version)
    else
      increment_version_code(gradle_file_path: "app/build.gradle")
    end

    # Build release Android App Bundle (AAB)
    gradle(
      task: "clean bundle",
      build_type: "Release"
    )

    # Upload to Play Store
    upload_to_play_store(
      track: track,
      aab: "./app/build/outputs/bundle/release/app-release.aab",
      release_status: "completed",
      skip_upload_apk: true
    )
  end

  desc "Deploy to closed testing track"
  
  lane :closed_testing do
    next_version = get_next_version_code
    if next_version
      increment_version_code(gradle_file_path: "app/build.gradle", version_code: next_version)
    else
      increment_version_code(gradle_file_path: "app/build.gradle")
    end

    # changelog = prompt(text: "Changelog: ")
    gradle(task: "bundle", build_type: "Release")
    upload_to_play_store(
      track: "alpha", # Options: 'internal', 'alpha', 'beta', 'production'
      aab: "./app/build/outputs/bundle/release/app-release.aab",
      release_status: "completed",
      skip_upload_apk: true
    )
  end

  desc "Deploy to production track"

  lane :production do
    next_version = get_next_version_code
    if next_version
      increment_version_code(gradle_file_path: "app/build.gradle", version_code: next_version)
    else
      increment_version_code(gradle_file_path: "app/build.gradle")
    end

    # changelog = prompt(text: "Changelog: ")
    gradle(task: "bundle", build_type: "Release")
    upload_to_play_store(
      track: "production", # Options: 'internal', 'alpha', 'beta', 'production'
      aab: "./app/build/outputs/bundle/release/app-release.aab",
      release_status: "completed",
      skip_upload_apk: true
    )
  end

end
